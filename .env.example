# Copy to `.env` and adjust locally ‚Äî never commit real secrets (see root `.gitignore`).
# Template consumed by `docker compose` (see `README.docker.md`).

# PostgreSQL superuser name created on first boot.
POSTGRES_USER=cbt_app

# Required in `.env` ‚Äî no safe default; use a strong value outside production.
POSTGRES_PASSWORD=change_me_local_only

# Database name created on first boot.
POSTGRES_DB=cognitive_bias_tester

# Host port mapped to container 5432. Default 5433 avoids clashing with a local PostgreSQL on 5432.
POSTGRES_PORT=5433

# Reserved for backend HTTP (FastAPI) in task T030.
BACKEND_PORT=8000

# Reserved for Vite dev server in task T050.
FRONTEND_PORT=5173
